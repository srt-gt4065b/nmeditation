# Firebase Admin SDK (서비스 계정 키 파일 경로)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Google Drive API (OAuth2 - Google Cloud Console에서 발급)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth2callback

# NotebookLM 노트북 ID
NOTEBOOKLM_NOTEBOOK_ID=53e7aa7c-e622-4bb5-a856-6d736dbd5ddd

# Google Drive 폴더 ID (NotebookLM 오디오가 저장되는 Drive 폴더, 비워두면 전체 Drive에서 검색)
GDRIVE_AUDIO_FOLDER_ID=

# 어드민 비밀번호 (Firestore 직접 쓰기용, 스크립트에서는 Service Account 사용)
ADMIN_PASSWORD=wky2026
